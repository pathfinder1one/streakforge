# ========================================
# StreakForge Production Environment
# ========================================

# Database
# Use postgresql:// for production instead of sqlite:///
DATABASE_URL="postgresql://forge_user:forge_pass@db:5432/streakforge"

# Security
# Generate a strong key for production (e.g., run `openssl rand -hex 32`)
SECRET_KEY="super-secret-key-change-me"

# CORS Origins
# List the exact domains that will access your API.
# Format must be a valid JSON array string.
CORS_ORIGINS='["https://streakforge.com", "https://www.streakforge.com"]'

# Optional APIs
# Gemini AI integration for Smart Difficulty and Custom Insights
# GEMINI_API_KEY="your-gemini-api-key"

# ========================================
# FUTURE EXTERNAL INTEGRATIONS (MOCKED UI)
# ========================================

# 1. Pro Subscriptions (Stripe)
# Cost: Free to setup, charges per transaction when live.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# 2. Google / GitHub OAuth (Login)
# Cost: Free
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# 3. Weekly Email Reports (Resend or SendGrid)
# Cost: Free Tier Available (e.g. Resend 3000/mo)
# RESEND_API_KEY="re_..."
# SENDGRID_API_KEY="SG..."

# 4. Google Calendar Sync
# Cost: Free (Requires Google Cloud OAuth scope setup)
# GOOGLE_CALENDAR_CLIENT_ID="your-calendar-client-id"

# 5. Cloudinary (Avatars / Image Uploads)
# Cost: Generous Free Tier
# CLOUDINARY_URL="cloudinary://my_key:my_secret@my_cloud_name"
